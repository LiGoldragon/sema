# Sema Language Layer — Field Type Classifications
# Every column of every new relation classified as: domain, bool, int, or data.
# No field left unclassified. No :Text on the wire.
#
# Conventions (same as noesis-schema):
#   kind=domain, target_domain=DomainName         -> capnp enum reference
#   kind=bool                                      -> capnp Bool
#   kind=int, target_domain=Measure, unit_domain=U -> capnp TypedInt
#   kind=data                                      -> capnp Data (content-addressed)

# ═══════════════════════════════════════════════════════════════════════
# LAYER 1 — Programming Logic Domains
# All are standard domain enums: (name, description, phase, dignity)
# ═══════════════════════════════════════════════════════════════════════

# Universal pattern: every domain enum has the same field types
# name=data, description=data, phase=Phase, dignity=Dignity

?[relation, column, kind, target_domain, unit_domain, description, phase, dignity] <- [
  ["Type", "name", "data", "", "", "Variant name — wire discriminant", "manifest", "eternal"],
  ["Type", "description", "data", "", "", "Human-readable description", "manifest", "eternal"],
  ["Type", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["Type", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],

  ["Op", "name", "data", "", "", "Operator name — wire discriminant", "manifest", "eternal"],
  ["Op", "description", "data", "", "", "Human-readable description", "manifest", "eternal"],
  ["Op", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["Op", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],

  ["Expr", "name", "data", "", "", "Expression constructor name", "manifest", "eternal"],
  ["Expr", "description", "data", "", "", "Human-readable description", "manifest", "eternal"],
  ["Expr", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["Expr", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],

  ["Control", "name", "data", "", "", "Control flow variant name", "manifest", "eternal"],
  ["Control", "description", "data", "", "", "Human-readable description", "manifest", "eternal"],
  ["Control", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["Control", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],

  ["Ownership", "name", "data", "", "", "Ownership mode name", "manifest", "eternal"],
  ["Ownership", "description", "data", "", "", "Human-readable description", "manifest", "eternal"],
  ["Ownership", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["Ownership", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],

  ["Binding", "name", "data", "", "", "Binding mode name", "manifest", "eternal"],
  ["Binding", "description", "data", "", "", "Human-readable description", "manifest", "eternal"],
  ["Binding", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["Binding", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],

  ["Arity", "name", "data", "", "", "Arity variant name", "manifest", "eternal"],
  ["Arity", "description", "data", "", "", "Human-readable description", "manifest", "eternal"],
  ["Arity", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["Arity", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],

  ["Pattern", "name", "data", "", "", "Pattern variant name", "manifest", "eternal"],
  ["Pattern", "description", "data", "", "", "Human-readable description", "manifest", "eternal"],
  ["Pattern", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["Pattern", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],

  ["Quantifier", "name", "data", "", "", "Quantifier variant name", "manifest", "eternal"],
  ["Quantifier", "description", "data", "", "", "Human-readable description", "manifest", "eternal"],
  ["Quantifier", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["Quantifier", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],

  ["Evaluation", "name", "data", "", "", "Evaluation strategy name", "manifest", "eternal"],
  ["Evaluation", "description", "data", "", "", "Human-readable description", "manifest", "eternal"],
  ["Evaluation", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["Evaluation", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],

  ["Cardinality", "name", "data", "", "", "Cardinality variant name", "manifest", "eternal"],
  ["Cardinality", "description", "data", "", "", "Human-readable description", "manifest", "eternal"],
  ["Cardinality", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["Cardinality", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],

  ["QueryKind", "name", "data", "", "", "Query kind variant name", "manifest", "eternal"],
  ["QueryKind", "description", "data", "", "", "Human-readable description", "manifest", "eternal"],
  ["QueryKind", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["QueryKind", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],

  ["ResponseKind", "name", "data", "", "", "Response kind variant name", "manifest", "eternal"],
  ["ResponseKind", "description", "data", "", "", "Human-readable description", "manifest", "eternal"],
  ["ResponseKind", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["ResponseKind", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],
]
:put field_type { relation, column => kind, target_domain, unit_domain, description, phase, dignity }

# ═══════════════════════════════════════════════════════════════════════
# LAYER 2 — Self-Describing Schema Relations
# ═══════════════════════════════════════════════════════════════════════

?[relation, column, kind, target_domain, unit_domain, description, phase, dignity] <- [
  ["schema_type", "schema_hash", "data", "", "", "Content-addressed schema identifier", "manifest", "eternal"],
  ["schema_type", "type_name", "data", "", "", "Type identifier within schema", "manifest", "eternal"],
  ["schema_type", "type_kind", "domain", "Type", "", "Structural kind of the type", "manifest", "eternal"],
  ["schema_type", "ordinal", "int", "L", "PositionUnit", "Position in schema", "manifest", "eternal"],
  ["schema_type", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["schema_type", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],

  ["schema_field", "schema_hash", "data", "", "", "Content-addressed schema identifier", "manifest", "eternal"],
  ["schema_field", "type_name", "data", "", "", "Owning type identifier", "manifest", "eternal"],
  ["schema_field", "field_name", "data", "", "", "Field identifier", "manifest", "eternal"],
  ["schema_field", "field_type_kind", "domain", "Type", "", "Structural kind of field type", "manifest", "eternal"],
  ["schema_field", "field_type_ref", "data", "", "", "Type reference (domain name or type name)", "manifest", "eternal"],
  ["schema_field", "ordinal", "int", "L", "PositionUnit", "Field ordinal in capnp layout", "manifest", "eternal"],
  ["schema_field", "cardinality", "domain", "Cardinality", "", "How many values this field holds", "manifest", "eternal"],
  ["schema_field", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["schema_field", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],

  ["schema_variant", "schema_hash", "data", "", "", "Content-addressed schema identifier", "manifest", "eternal"],
  ["schema_variant", "type_name", "data", "", "", "Owning enum type identifier", "manifest", "eternal"],
  ["schema_variant", "variant_name", "data", "", "", "Variant identifier", "manifest", "eternal"],
  ["schema_variant", "ordinal", "int", "L", "PositionUnit", "Variant ordinal (capnp discriminant)", "manifest", "eternal"],
  ["schema_variant", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["schema_variant", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],

  ["schema_method", "schema_hash", "data", "", "", "Content-addressed schema identifier", "manifest", "eternal"],
  ["schema_method", "interface_name", "data", "", "", "Interface identifier", "manifest", "eternal"],
  ["schema_method", "method_name", "data", "", "", "Method identifier", "manifest", "eternal"],
  ["schema_method", "ordinal", "int", "L", "PositionUnit", "Method ordinal", "manifest", "eternal"],
  ["schema_method", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["schema_method", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],

  ["schema_method_param", "schema_hash", "data", "", "", "Content-addressed schema identifier", "manifest", "eternal"],
  ["schema_method_param", "interface_name", "data", "", "", "Interface identifier", "manifest", "eternal"],
  ["schema_method_param", "method_name", "data", "", "", "Method identifier", "manifest", "eternal"],
  ["schema_method_param", "param_name", "data", "", "", "Parameter identifier", "manifest", "eternal"],
  ["schema_method_param", "direction", "domain", "Direction", "", "Request or response parameter", "manifest", "eternal"],
  ["schema_method_param", "param_type_kind", "domain", "Type", "", "Structural kind of parameter type", "manifest", "eternal"],
  ["schema_method_param", "param_type_ref", "data", "", "", "Type reference for parameter", "manifest", "eternal"],
  ["schema_method_param", "ordinal", "int", "L", "PositionUnit", "Parameter ordinal", "manifest", "eternal"],
  ["schema_method_param", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["schema_method_param", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],
]
:put field_type { relation, column => kind, target_domain, unit_domain, description, phase, dignity }

# ═══════════════════════════════════════════════════════════════════════
# LAYER 3 + TRAINING — Session and Trial Relations
# ═══════════════════════════════════════════════════════════════════════

?[relation, column, kind, target_domain, unit_domain, description, phase, dignity] <- [
  ["session", "session_id", "data", "", "", "Content-addressed session identifier", "manifest", "eternal"],
  ["session", "model", "data", "", "", "LLM model identifier", "manifest", "eternal"],
  ["session", "schema_hash", "data", "", "", "Schema hash used in this session", "manifest", "eternal"],
  ["session", "domain_count", "int", "ML/T²", "CountUnit", "Number of domains in schema", "manifest", "eternal"],
  ["session", "variant_count", "int", "ML/T²", "CountUnit", "Number of total variants", "manifest", "eternal"],
  ["session", "started_ts", "data", "", "", "ISO 8601 session start timestamp", "manifest", "eternal"],
  ["session", "ended_ts", "data", "", "", "ISO 8601 session end timestamp", "manifest", "eternal"],
  ["session", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["session", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],

  ["session_turn", "session_id", "data", "", "", "Parent session identifier", "manifest", "eternal"],
  ["session_turn", "turn_id", "int", "L", "PositionUnit", "Turn sequence number within session", "manifest", "eternal"],
  ["session_turn", "query_kind", "domain", "QueryKind", "", "What the LLM asked", "manifest", "eternal"],
  ["session_turn", "arg0", "int", "L", "PositionUnit", "Primary argument (type ordinal, domain ordinal)", "manifest", "eternal"],
  ["session_turn", "arg1", "int", "L", "PositionUnit", "Secondary argument", "manifest", "eternal"],
  ["session_turn", "arg2", "int", "L", "PositionUnit", "Tertiary argument", "manifest", "eternal"],
  ["session_turn", "response_kind", "domain", "ResponseKind", "", "What the harness responded with", "manifest", "eternal"],
  ["session_turn", "result_count", "int", "ML/T²", "CountUnit", "Number of results returned", "manifest", "eternal"],
  ["session_turn", "latency_ms", "int", "ML²/T³", "TimeUnit", "Response latency in milliseconds", "manifest", "eternal"],
  ["session_turn", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["session_turn", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],

  ["trial", "session_id", "data", "", "", "Parent session identifier", "manifest", "eternal"],
  ["trial", "trial_id", "int", "L", "PositionUnit", "Trial sequence number", "manifest", "eternal"],
  ["trial", "target_type", "data", "", "", "Type name the LLM attempted to encode", "manifest", "eternal"],
  ["trial", "target_ordinal", "int", "L", "PositionUnit", "Ordinal of target in schema", "manifest", "eternal"],
  ["trial", "expected_hash", "data", "", "", "Blake3 hash of expected binary output", "manifest", "eternal"],
  ["trial", "actual_hash", "data", "", "", "Blake3 hash of actual LLM output", "manifest", "eternal"],
  ["trial", "expected_size", "int", "ML²", "SizeUnit", "Expected binary size in bytes", "manifest", "eternal"],
  ["trial", "actual_size", "int", "ML²", "SizeUnit", "Actual binary size in bytes", "manifest", "eternal"],
  ["trial", "pass", "bool", "", "", "Whether expected_hash == actual_hash", "manifest", "eternal"],
  ["trial", "byte_errors", "int", "ML/T²", "CountUnit", "Number of incorrect bytes", "manifest", "eternal"],
  ["trial", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["trial", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],

  ["model_score", "model", "data", "", "", "LLM model identifier", "manifest", "eternal"],
  ["model_score", "schema_hash", "data", "", "", "Schema hash scored against", "manifest", "eternal"],
  ["model_score", "total_trials", "int", "ML/T²", "CountUnit", "Total encoding trials attempted", "manifest", "eternal"],
  ["model_score", "pass_count", "int", "ML/T²", "CountUnit", "Number of trials that passed", "manifest", "eternal"],
  ["model_score", "fail_count", "int", "ML/T²", "CountUnit", "Number of trials that failed", "manifest", "eternal"],
  ["model_score", "mean_byte_errors", "int", "ML/T²", "CountUnit", "Average byte errors across failures", "manifest", "eternal"],
  ["model_score", "last_session_ts", "data", "", "", "Timestamp of most recent session", "manifest", "eternal"],
  ["model_score", "phase", "domain", "Phase", "", "Lifecycle phase", "manifest", "eternal"],
  ["model_score", "dignity", "domain", "Dignity", "", "Epistemological trust", "manifest", "eternal"],
]
:put field_type { relation, column => kind, target_domain, unit_domain, description, phase, dignity }
