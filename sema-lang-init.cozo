# Sema Language Layer — Application domains + operational relations
# Loads AFTER sema-core. Programming domains use the triad pattern.
# Composition TBD — these are application-layer, not primordial.

# ═══════════════════════════════════════════════════════════════════════
# Programming Logic Domains (application layer)
# ═══════════════════════════════════════════════════════════════════════

:create Op {
  ordinal: Int =>
  variant: String,
  structure: String
}

:create Expr {
  ordinal: Int =>
  variant: String,
  structure: String
}

:create Control {
  ordinal: Int =>
  variant: String,
  structure: String
}

:create Ownership {
  ordinal: Int =>
  variant: String,
  structure: String
}

:create Binding {
  ordinal: Int =>
  variant: String,
  structure: String
}

:create Arity {
  ordinal: Int =>
  variant: String,
  structure: String
}

:create Pattern {
  ordinal: Int =>
  variant: String,
  structure: String
}

:create Quantifier {
  ordinal: Int =>
  variant: String,
  structure: String
}

:create Evaluation {
  ordinal: Int =>
  variant: String,
  structure: String
}

:create Query {
  ordinal: Int =>
  variant: String,
  structure: String
}

:create Response {
  ordinal: Int =>
  variant: String,
  structure: String
}

# ═══════════════════════════════════════════════════════════════════════
# Operational relations — session logging for LLM binary experiments
# ═══════════════════════════════════════════════════════════════════════

:create session {
  session_id: String =>
  model: String,
  schema_hash: String,
  domain_count: Int,
  variant_count: Int,
  started_ts: String,
  ended_ts: String,
  phase: String
}

:create session_turn {
  session_id: String,
  turn_id: Int =>
  query: String,
  arg0: Int, arg1: Int, arg2: Int,
  response: String,
  result_count: Int,
  latency_ms: Int,
  phase: String
}

:create trial {
  session_id: String,
  trial_id: Int =>
  target: String,
  target_ordinal: Int,
  expected_hash: String,
  actual_hash: String,
  expected_size: Int,
  actual_size: Int,
  pass: Bool,
  byte_errors: Int,
  phase: String
}

:create model_score {
  model: String,
  schema_hash: String =>
  total_trials: Int,
  pass_count: Int,
  fail_count: Int,
  mean_byte_errors: Int,
  last_session_ts: String,
  phase: String
}
