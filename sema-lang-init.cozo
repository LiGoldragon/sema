# Sema Language Layer — Programming Logic + Protocol + Testing
# Loads AFTER sema-core. Depends on: Phase, Dignity, Type, Scalar,
# Cardinality, Direction, field, schema_*, Domain, morphism.
#
# Load order: sema-core -> sema -> noesis

# ═══════════════════════════════════════════════════════════════════════
# Programming Logic Domains
# The irreducible vocabulary for expressing computation and structure.
# ═══════════════════════════════════════════════════════════════════════

# All operators — logical, comparison, arithmetic (Frege primitives + extensions)
:create Op {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# Abstract syntax constructors (Ranta GF — AST nodes)
:create Expr {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# Control flow — Tesniere translation (category-changing operations)
:create Control {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# Memory ownership semantics — Tesniere translation applied to memory
:create Ownership {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# Variable binding mode — Ranta dependent type context
:create Binding {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# Tesniere valency — number of arguments an operator takes
:create Arity {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# Dignaga apoha — exclusion-based pattern matching
:create Pattern {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# Frege third primitive — quantification over domains
:create Quantifier {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# Dignaga pratyaksa/anumana as computation strategy
:create Evaluation {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# ═══════════════════════════════════════════════════════════════════════
# Query Protocol — CSP traces over finite event alphabet
# ═══════════════════════════════════════════════════════════════════════

:create Query {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

:create Response {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# ═══════════════════════════════════════════════════════════════════════
# Training and Testing — session logging for LLM binary experiments
# ═══════════════════════════════════════════════════════════════════════

:create session {
  session_id: String =>
  model: String,
  schema_hash: String,
  domain_count: Int,
  variant_count: Int,
  started_ts: String,
  ended_ts: String,
  phase: String,
  dignity: String
}

:create session_turn {
  session_id: String,
  turn_id: Int =>
  query: String,
  arg0: Int,
  arg1: Int,
  arg2: Int,
  response: String,
  result_count: Int,
  latency_ms: Int,
  phase: String,
  dignity: String
}

:create trial {
  session_id: String,
  trial_id: Int =>
  target: String,
  target_ordinal: Int,
  expected_hash: String,
  actual_hash: String,
  expected_size: Int,
  actual_size: Int,
  pass: Bool,
  byte_errors: Int,
  phase: String,
  dignity: String
}

:create model_score {
  model: String,
  schema_hash: String =>
  total_trials: Int,
  pass_count: Int,
  fail_count: Int,
  mean_byte_errors: Int,
  last_session_ts: String,
  phase: String,
  dignity: String
}
