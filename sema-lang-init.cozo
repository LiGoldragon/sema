# Sema Language Layer — String-Free Programming Logic
# Three layers: (1) programming logic domains, (2) self-describing schema,
# (3) query protocol. Plus training/testing session relations.
#
# Sema IS the typed schema layer. All relations here are consumed by
# lojix-macros via include_str! and drive capnp codegen through samskara-codegen.

# ═══════════════════════════════════════════════════════════════════════
# LAYER 1 — Programming Logic Domains
# The irreducible vocabulary for expressing computation and structure.
# These become capnp enums via samskara-codegen. ~88 variants, 13 domains.
# ═══════════════════════════════════════════════════════════════════════

# What structural form a type has (Sowa lattice atoms, DOLCE foundational categories)
:create Type {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# All operators — logical, comparison, arithmetic (Frege primitives + extensions)
:create Op {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# Abstract syntax constructors (Ranta GF — AST nodes)
:create Expr {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# Control flow — Tesniere translation (category-changing operations)
:create Control {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# Memory ownership semantics — Tesniere translation applied to memory
:create Ownership {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# Variable binding mode — Ranta dependent type context
:create Binding {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# Tesniere valency — number of arguments an operator takes
:create Arity {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# Dignaga apoha — exclusion-based pattern matching
:create Pattern {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# Frege third primitive — quantification over domains
:create Quantifier {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# Dignaga pratyaksa/anumana as computation strategy
:create Evaluation {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# Field multiplicity — how many values a field holds
:create Cardinality {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# ═══════════════════════════════════════════════════════════════════════
# LAYER 2 — Self-Describing Schema (capnp in capnp)
# Uses Layer 1 domains to describe capnp structure as samskara relations.
# The LLM queries these to learn what types exist on demand.
# Closes at 2 meta-levels (AMOP metaclass pattern).
# ═══════════════════════════════════════════════════════════════════════

# A schema is a set of type definitions
:create schema_entry {
  schema: String,
  name: String =>
  structure: String,
  ordinal: Int,
  phase: String,
  dignity: String
}

# Each type has fields (structs) or variants (enums)
:create schema_field {
  schema: String,
  owner: String,
  name: String =>
  structure: String,
  target: String,
  ordinal: Int,
  cardinality: String,
  phase: String,
  dignity: String
}

:create schema_variant {
  schema: String,
  owner: String,
  name: String =>
  ordinal: Int,
  phase: String,
  dignity: String
}

# Methods on interfaces
:create schema_method {
  schema: String,
  interface: String,
  name: String =>
  ordinal: Int,
  phase: String,
  dignity: String
}

:create schema_param {
  schema: String,
  interface: String,
  method: String,
  name: String =>
  direction: String,
  structure: String,
  target: String,
  ordinal: Int,
  phase: String,
  dignity: String
}

# ═══════════════════════════════════════════════════════════════════════
# LAYER 3 — Query Protocol
# The LLM communicates with samskara through typed multi-turn protocol.
# Each turn is a fixed-size capnp struct. No variable-length strings.
# Protocol formalized as CSP traces over finite event alphabet.
# ═══════════════════════════════════════════════════════════════════════

# What the LLM can ask (CSP event alphabet — request side)
:create Query {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# What the harness responds with (CSP event alphabet — response side)
:create Response {
  name: String =>
  description: String,
  phase: String,
  dignity: String
}

# ═══════════════════════════════════════════════════════════════════════
# TRAINING AND TESTING — Session logging for LLM binary experiments
# Results tracked as relations for analysis. Every trial is a fact.
# ═══════════════════════════════════════════════════════════════════════

# A test session: one multi-turn conversation with an LLM
:create session {
  session_id: String =>
  model: String,
  schema_hash: String,
  domain_count: Int,
  variant_count: Int,
  started_ts: String,
  ended_ts: String,
  phase: String,
  dignity: String
}

# One turn within a session
:create session_turn {
  session_id: String,
  turn_id: Int =>
  query: String,
  arg0: Int,
  arg1: Int,
  arg2: Int,
  response: String,
  result_count: Int,
  latency_ms: Int,
  phase: String,
  dignity: String
}

# One encoding trial: LLM attempts to produce correct binary
:create trial {
  session_id: String,
  trial_id: Int =>
  target: String,
  target_ordinal: Int,
  expected_hash: String,
  actual_hash: String,
  expected_size: Int,
  actual_size: Int,
  pass: Bool,
  byte_errors: Int,
  phase: String,
  dignity: String
}

# Aggregate results per model across sessions
:create model_score {
  model: String,
  schema_hash: String =>
  total_trials: Int,
  pass_count: Int,
  fail_count: Int,
  mean_byte_errors: Int,
  last_session_ts: String,
  phase: String,
  dignity: String
}
